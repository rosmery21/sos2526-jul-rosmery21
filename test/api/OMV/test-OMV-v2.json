        {
          "name": "GET year filter (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Convertir la respuesta a un objeto JSON\r",
                  "const responseData = pm.response.json();\r",
                  "\r",
                  "// Validar que el código de estado sea 200\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Validar que el resultado contiene exactamente 5 elementos (según el query param limit=5)\r",
                  "pm.test(\"Se devuelven exactamente 5 registros\", function () {\r",
                  "    pm.expect(responseData).to.be.an('array');\r",
                  "    pm.expect(responseData.length).to.equal(5);\r",
                  "});\r",
                  "\r",
                  "// Validar que todos los años estén en el rango de 1990 a 2000\r",
                  "pm.test(\"Todos los años están en el rango 1990 - 2000\", function () {\r",
                  "    const fromYear = 1990;\r",
                  "    const toYear = 2000;\r",
                  "    \r",
                  "    responseData.forEach((item) => {\r",
                  "        pm.expect(item.year).to.be.at.least(fromYear);\r",
                  "        pm.expect(item.year).to.be.at.most(toYear);\r",
                  "    });\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
