                        "exec": [
                          "pm.test(\"Status code is 201 or 409 or 400\", function () {\r",
                          "    pm.expect(pm.response.code).to.be.oneOf([201,400,409]);\r",
                          "});\r",
                          "\r",
                          "if (pm.response.code === 201) {\r",
                          "    let jsonData = pm.response.json();\r",
                          "\r",
                          "    pm.test(\"Created object has entity\", function () {\r",
                          "        pm.expect(jsonData.entity).to.eql(\"Spain\");\r",
                          "    });\r",
                          "\r",
                          "    pm.test(\"Created object has year\", function () {\r",
                          "        pm.expect(jsonData.year).to.eql(2020);\r",
                          "    });\r",
                          "}"
                        ],
                        "type": "text/javascript",
                        "packages": {},
                        "requests": {}
                      }
